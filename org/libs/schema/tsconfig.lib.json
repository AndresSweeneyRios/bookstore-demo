{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "module": "nodenext",
    "target": "es2022",
    "types": ["node"],
    "rootDir": "src",
    "noEmit": false,
    "moduleResolution": "nodenext",
    "esModuleInterop": true,
    "emitDeclarationOnly": true,
    "declaration": true,
  },
  "include": ["src/**/*.ts"],
  "exclude": []
}
